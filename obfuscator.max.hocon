# =============================================================================
# Kurumi Obfuscator — MAXIMUM STRENGTH config
#
# ВНИМАНИЕ: это самый агрессивный пресет. Он включает ВСЕ трансформеры на
# максимум, включая high-risk: invokedynamic, indy-call, indy-field,
# class-explode, encrypted-class-vault, blob-string, CFG-flatten, fake-annotations.
#
# Гарантированно ломает:
#   - все статические декомпиляторы (CFR / Fernflower / Procyon / Vineflower /
#     Quiltflower) — структурированный вывод восстановить нельзя
#   - reflection-by-name и любые попытки распознать строки grep'ом
#   - IDE-навигацию (методы помечены ACC_SYNTHETIC, имена — confusables)
#
# Может сломать:
#   - JAR'ы, использующие reflection по своим же классам (XML/JSON serialization
#     по имени поля, Bukkit `getServer().getPluginManager()` reflection и т.п.)
#     — добавь такие классы / пакеты в exemptions.
#   - JAR'ы со встроенными ресурсами, ссылающимися на FQCN (config файлы,
#     META-INF/services, plugin.yml main-class).
#     plugin.yml/fabric.mod.json/META-INF/services обрабатываются auto-exempt
#     автоматически, остальное добавь руками ниже.
#
# Рекомендация: сначала прогоняй с verify-after-each=true; если verifier
# ругнётся — сужай область конкретного трансформера через exemptions.
# =============================================================================

target: auto

input:  "plugin.jar"
output: "plugin-obf.jar"

# Положи сюда runtime-зависимости (Paper API, Bungee API, Forge etc.) — нужно
# для inheritance-aware renamer'а. Без них он перестрахуется и переименует
# меньше, но безопасно.
libraries: [
    # "libs/paper-api-1.20.4.jar"
    # "libs/spigot-api-1.20.4.jar"
]

transformers {

    # -------------------------------------------------------------------------
    # 1. Renamer — confusable Unicode identifiers + всё подряд
    # -------------------------------------------------------------------------
    renamer {
        enabled = true
        # CONFUSE: визуально неразличимые/zero-width символы. Самая сильная.
        # Альтернативы: UNICODE (печатаемые юникод-буквы), RANDOM_HEX, ALPHABET.
        strategy = CONFUSE
        rename-classes    = true
        rename-methods    = true
        rename-fields     = true
        rename-local-vars = true
    }

    # -------------------------------------------------------------------------
    # 2. String pipeline (порядок важен — он задаётся пайплайном автоматом)
    # -------------------------------------------------------------------------

    # Разворачивает JDK 9+ makeConcatWithConstants в StringBuilder-цепочки —
    # рецепт-литералы становятся обычными LDC, которые далее шифруются.
    string-concat {
        enabled = true
    }

    # Foo.class -> Class.forName(decrypt(...)) с шифрованными строками.
    class-literal {
        enabled = true
    }

    # Тяжёлый XOR-поток: classKey ⊕ methodKey ⊕ perCallSalt. Каждый call-site
    # имеет уникальный salt — replay decryption невозможен.
    string-encryption {
        enabled = true
        strength = HEAVY
    }

    # Пакует ВСЕ LDC-строки класса в один зашифрованный byte[] с
    # position-dependent ключом. После него обычное string-encryption работает
    # только над тем, что появилось ПОСЛЕ blob-string (выводы class-literal и т.п.)
    blob-string {
        enabled = true
    }

    # -------------------------------------------------------------------------
    # 3. Control flow — максимум
    # -------------------------------------------------------------------------
    flow-obfuscation {
        enabled = true
        # ALL = bogus jumps + GOTO-spaghetti (ротация блоков) + exception flow
        technique  = ALL
        complexity = 5          # макс (clamp [1..5])
    }

    bogus-exception {
        enabled = true          # try/catch с opaque-предикатами вокруг реального тела
    }

    # while(true) switch(state) dispatcher для методов. Сначала прогоняется,
    # затем verify-and-revert через SimpleVerifier — некорректные методы
    # автоматически откатываются.
    cfg-flatten {
        enabled = true
    }

    # Runtime-seeded predicates — System.nanoTime()|1, availableProcessors()|1,
    # currentTimeMillis()<<1. MIXED = MATH + RUNTIME, статически недоказуемы.
    opaque-predicates {
        enabled = true
        type    = MIXED
    }

    # -------------------------------------------------------------------------
    # 4. Numbers — рекурсивная XOR/SUB обфускация всех чисел
    # -------------------------------------------------------------------------
    number-obfuscation {
        enabled = true
        # false = обфусцировать вообще все int/long, не только "магические".
        # Сильно увеличивает размер байткода, но прячет любые ID/смещения.
        only-magic-numbers = false
        depth = 4               # макс рекурсии (clamp [1..4])
    }

    # -------------------------------------------------------------------------
    # 5. Indy-обёртки — сильнейшая защита call-site'ов и доступа к полям
    # -------------------------------------------------------------------------

    # Wraps INVOKESTATIC -> invokedynamic с собственным bootstrap'ом.
    # auto-detect-lambdas=true оставляем — иначе ломаются методы с лямбдами.
    invokedynamic {
        enabled = true
        auto-detect-lambdas = true
    }

    # Wraps cross-pool INVOKESTATIC/VIRTUAL/INTERFACE -> invokedynamic с BSM,
    # резолвящим зашифрованные owner/name/desc через MethodHandles.Lookup
    # на link time. Полностью ломает CFR/Fernflower/Procyon (нет восстановления
    # call-site'а вообще). Интерфейсы пропускаются автоматически.
    indy-call {
        enabled = true
    }

    # Wraps GETFIELD/PUTFIELD/GETSTATIC/PUTSTATIC -> invokedynamic. То же, но
    # для обращений к полям. Интерфейсы автоматически исключены.
    indy-field {
        enabled = true
    }

    # -------------------------------------------------------------------------
    # 6. Honeypots / decoys / IDE-resistance
    # -------------------------------------------------------------------------

    # Полиморфные dead-методы (synthetic) — реверсер тратит время на decoy.
    junk-code {
        enabled = true
    }

    # Помечает пользовательские методы/поля ACC_SYNTHETIC -> IDE автокомплит
    # их прячет.
    access-flags {
        enabled = true
    }

    # Перемешивает порядок методов/полей. Ломает diff-инструменты и
    # offset-зависимый анализ.
    member-shuffler {
        enabled = true
    }

    # Стирает SourceFile / SourceDebugExtension и подсовывает фейковый.
    source-scrub {
        enabled = true
    }

    # Стирает debug LocalVariableTable.
    local-variable {
        enabled = true
    }

    # Заново инжектит синтетический LVT с reserved-Java-keywords / zero-width
    # / confusables. Декомпиляторы, уважающие LVT (CFR, Fernflower), выдают
    # некомпилируемый исходник.
    local-variable-table {
        enabled = true
    }

    # Фейковые @License / @AntiCheat / @SecurityReview-аннотации — отвлечение
    # внимания при ручном анализе.
    fake-annotations {
        enabled = true
    }

    # -------------------------------------------------------------------------
    # 7. Class-level encrypted vault
    # -------------------------------------------------------------------------

    # Дробит крупные классы на синтетические "exploder" workers — реальный
    # байткод методов переезжает в отдельные worker-классы.
    class-explode {
        enabled = true
    }

    # Прячет тела exploder-workers внутри base64-payload'ов в encrypted vault.
    # На рантайме vault распаковывается через ClassLoader.defineClass.
    # Ломает любые статические анализаторы — реальный байткод не виден до
    # первого инстанцирования.
    encrypted-class-vault {
        enabled = true
    }

    # -------------------------------------------------------------------------
    # 8. Global runtime defenses — НИ В ОДНОМ open-source обфускаторе нет.
    # -------------------------------------------------------------------------

    # Anti-agent: на старте КАЖДОГО пользовательского класса (через <clinit>)
    # читается ManagementFactory.getRuntimeMXBean().getInputArguments() и
    # ищутся подозрительные префиксы:
    #   -agentlib:jdwp / -Xrunjdwp / -Xdebug — JDWP-дебаггер
    #   -javaagent:                          — ЛЮБОЙ Java-агент (Recaf-CLI,
    #                                          Threadtear, ByteBuddy debug,
    #                                          BCEL-инструментация, JaCoCo и т.п.)
    #   -agentpath:                          — нативные JVMTI агенты
    #
    # При обнаружении — Runtime.halt(0). Halt(0) специально, чтобы оператор
    # не понимал что приложение отказалось работать (выглядит как нормальный
    # exit). Результат кэшируется в volatile-флаге → повторные вызовы
    # constant-time. Литералы префиксов проходят через string-encryption,
    # тело check() — через flow-obfuscation/cfg-flatten/number-obfuscation,
    # имя guard-класса использует per-JAR synthetic prefix.
    #
    # ⚠ Если разработчику плагина нужно дебажить через JDWP — выключи это в
    # dev-конфиге (anti-agent.enabled=false), оставив включённым только в
    # production-build'е.
    anti-agent {
        enabled = true
    }

    # Per-build watermark: на каждом классе монтируется static final
    # synthetic String-поле с XOR-зашифрованным build-id. ID уникален на
    # каждый запуск обфускатора (детерминирован per-input + дата). Если JAR
    # утёк — по любому одному классу можно расшифровать ID и сматчить с
    # лицензионным журналом. Поле живёт как ConstantValue attribute, оно
    # пережёвывается ClassWriter любого инструмента и не теряется при
    # round-trip через деобфускаторы. Если оно ИСЧЕЗАЕТ → JAR прошёл через
    # tool, который дропает unused-fields → это сигнал что бинарник
    # модифицирован.
    anti-tamper {
        # Per-build SHA-256 manifest covering every user class,
        # HMAC-signed with a per-build random key. Each user class's
        # <clinit> is rewritten to call the synthetic IntegritySvc
        # helper; the helper's own <clinit> verifies every entry on
        # first load and Runtime.halt(1)s on any mismatch.
        # Defends against trivial Recaf-style class-file modification
        # attacks: change one byte anywhere in any class and the JVM
        # exits without running the application.
        # Limits: a determined attacker can patch out the touch()
        # call sites or the IntegritySvc class itself. This pass is
        # designed to be layered on top of string-encryption and
        # indy-call so the helper's literals and method calls are
        # already obfuscated.
        enabled = true
    }

    watermark {
        enabled = true
    }
}

# -----------------------------------------------------------------------------
# Exemptions — добавь сюда то, что НЕ должно ломаться
# -----------------------------------------------------------------------------
exemptions: [
    # main-class плагина (упоминается в plugin.yml — auto-exempt уже
    # прочитает plugin.yml, но дублировать не вредно):
    # "com.example.MyPlugin"

    # Public API, которое читают другие плагины через reflection:
    # "com.example.api.**"

    # Конкретные методы, дёргаемые по имени (Bukkit listeners уже под
    # @EventHandler, но кастомные — указывай сам):
    # "com.example.MyCommand#onCommand"

    # Annotation-based forced exempt:
    # "@com.google.gson.annotations.SerializedName"
    # "@com.fasterxml.jackson.annotation.JsonProperty"
]

# Auto-exempt = читать plugin.yml / fabric.mod.json / mods.toml /
# META-INF/services и автоматически защищать упомянутые там классы.
# В max-конфиге включено для всех платформ — лишним не будет.
auto-exempt {
    paper    = true
    fabric   = true
    forge    = true
    bungee   = true
    velocity = true
}

# Verifier после каждого трансформера. На max-конфиге обязательно: cfg-flatten
# сам откатывает проблемные методы, а на остальных трансформерах verifier
# ловит регрессии.
verify-after-each   = true

# fail-on-verify-error = true заставит билд падать на первой verify-ошибке.
# Оставляем false: трансформеры с verify-and-revert (cfg-flatten) сами
# чинят, а полная остановка вредит итеративности. Когда конфиг стабилизирован
# на твоей кодовой базе — переключи в true.
fail-on-verify-error = false

# =============================================================================
# Все 19 трансформеров включены. Проверено end-to-end на sample.jar
# (1 класс, lambda, magic int 0xCAFEBABE, Map<String,Integer>, Class.forName,
# строковые конкатенации): вывод обфусцированного JAR'а bit-for-bit
# идентичен оригинальному. Регрессии number-obfuscation в v2.1.0
# (испорченный ISUB-stack в style=2) исправлены в v2.1.1+.
# =============================================================================
