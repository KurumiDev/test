# Example obfuscator config. Copy to obfuscator.hocon and edit to taste.

target: auto

input:  "plugin.jar"
output: "plugin-obf.jar"

libraries: []

transformers {
    renamer {
        enabled = true
        strategy = ALPHABET          # ALPHABET | UNICODE | CONFUSE | RANDOM_HEX
        rename-classes = true
        rename-methods = true
        rename-fields  = true
        rename-local-vars = true
    }

    string-encryption {
        enabled = true
        strength = STANDARD          # LIGHT | STANDARD | HEAVY
    }

    flow-obfuscation {
        enabled = true
        technique = BOGUS_JUMPS      # BOGUS_JUMPS | EXCEPTION | GOTO_SPAGHETTI | ALL
        complexity = 2
    }

    bogus-exception {
        enabled = false
    }

    opaque-predicates {
        enabled = true
        type = MATH                  # MATH | RUNTIME | MIXED
    }

    number-obfuscation {
        enabled = true
        only-magic-numbers = true
    }

    invokedynamic {
        enabled = false              # keep off when lambdas are present
        auto-detect-lambdas = true
    }

    # Rewrites Foo.class references into Class.forName(decrypt(…)).
    class-literal {
        enabled = true
    }

    # Expands makeConcatWithConstants into StringBuilder chains so the
    # recipe string literals become LDC constants that downstream string
    # encryption can wrap.
    string-concat {
        enabled = true
    }

    # Packs all LDC strings of a class into a single encrypted byte[] blob
    # with a position-dependent key schedule. Alternative to per-string XOR
    # encryption; when enabled, regular string-encryption processes only
    # strings that appear AFTER this pass (class-literal output, etc.).
    blob-string {
        enabled = false              # opt-in, heavier
    }

    # Wraps cross-pool INVOKESTATIC/VIRTUAL/INTERFACE calls in invokedynamic
    # with a custom bootstrap that resolves encrypted owner/name/descriptor
    # at link time. Breaks CFR/Fernflower/Procyon completely.
    indy-call {
        enabled = false              # opt-in, strongest
    }

    # Injects realistic-looking dead synthetic methods as reverser traps.
    junk-code {
        enabled = true
    }

    # Marks user methods/fields ACC_SYNTHETIC so IDEs hide them from
    # autocomplete.
    access-flags {
        enabled = true
    }

    # Randomizes method/field order within each class. Breaks diff tools.
    member-shuffler {
        enabled = true
    }

    # Strips SourceFile/SourceDebugExtension and injects a plausible fake.
    source-scrub {
        enabled = true
    }

    # Strips the debug LocalVariableTable attribute.
    local-variable {
        enabled = true
    }

    # Injects a synthetic LocalVariableTable with reserved Java keywords /
    # zero-width chars / confusables as variable names. Decompilers that
    # respect the LVT (CFR, Fernflower) will emit uncompilable source.
    local-variable-table {
        enabled = true
    }
}

exemptions: [
    # Full class name:
    # "com.example.MyPlugin.MyListener"

    # Recursive package:
    # "com.example.api.**"

    # Member rule:
    # "com.example.MyCommand#onCommand"

    # Annotation-based (already auto-applied by auto-exempt, but can be forced):
    # "@org.bukkit.event.EventHandler"
]

auto-exempt {
    paper    = true
    fabric   = true
    forge    = true
    bungee   = true
    velocity = true
}

verify-after-each = true
fail-on-verify-error = false
